                                "Protohedron",
                                "協約角柱セット"
                            ]
                        },
                        "BuyFirstOCR_CanNotAfford_Protohedron": {
                            "expected": [
                                "协议棱柱组",
                                "協議稜柱組",
                                "Protohedron",
                                "協約角柱セット"
                            ]
