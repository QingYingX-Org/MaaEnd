{
    "task": [
        {
            "name": "CreditShoppingN2",
            "label": "$task.CreditShopping.label",
            "entry": "CreditShoppingMain",
            "description": "$task.CreditShopping.description",
            "option": [
                "CreditShoppingOptions",
                "CreditShoppingBlackOptions",
                "AutoGetCredits",
                "CreditShoppingForce",
                "CreditShoppingReserve",
                "CreditShoppingOtherItems"
            ],
            "group": ["daily"]
        }
    ],
    "option": {
        "CreditShoppingOptions": {
            "type": "checkbox",
            "label": "$option.CreditShoppingOptions.label",
            "default_case": [
                "Oroberyl",
                "ArsenalTicket"
            ],
            "cases": [
                {
                    "name": "Oroberyl",
                    "label": "$option.CreditShoppingItems.cases.Oroberyl.label",
                    "pipeline_override": {
                        "BuyFirstOCR_Oroberyl": {
